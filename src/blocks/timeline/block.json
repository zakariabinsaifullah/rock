{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "rsf/timeline",
    "version": "1.0.0",
    "title": "Timeline",
    "category": "rsf",
    "icon": "star-filled",
    "description": "Vertical timeline with customizable items.",
    "example": {},
    "supports": {
        "anchor": true,
        "html": false,
        "align": ["wide", "full"],
        "spacing": {
            "margin": true,
            "padding": true,
            "__experimentalDefaultControls": {
                "margin": false,
                "padding": false
            }
        }
    },
    "attributes": {
        "uniqueId": {
            "type": "string"
        },
        "contentGap": {
            "type": "number"
        }
    },
    "textdomain": "rock-solid-financials",
    "editorScript": "file:./index.js",
    "style": "file:./style-index.css"
}
