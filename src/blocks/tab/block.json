{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "rsf/tab",
    "version": "0.1.0",
    "title": "Tab",
    "category": "rsf",
    "parent": ["rsf/tabs"],
    "description": "A single tab panel within a Tabs block.",
    "supports": {
        "anchor": true,
        "html": false,
        "align": ["wide", "full"],
        "spacing": {
            "margin": true,
            "padding": true,
            "__experimentalDefaultControls": {
                "margin": false,
                "padding": false
            }
        }
    },
    "attributes": {
        "uniqueId": {
            "type": "string"
        },
        "blockStyle": {
            "type": "object"
        },
        "tabId": {
            "type": "string"
        },
        "parentTabId": {
            "type": "string"
        }
    },
    "textdomain": "rsf",
    "editorScript": "file:./index.js",
    "editorStyle": "file:./index.css",
    "style": "file:./style-index.css"
}
