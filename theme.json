                {
                    "name": "Trebuchet MS",
                    "slug": "trebuchet-ms",
                    "fontFamily": "\"Trebuchet MS\", sans-serif",
                    "fontFace": [
                        {
                            "src": ["file:./assets/fonts/trebuchet-ms/Trebuchet-MS.woff2"],
                            "fontWeight": "400",
                            "fontStyle": "normal",
