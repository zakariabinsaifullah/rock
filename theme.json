                        },
                        {
                            "src": ["file:./assets/fonts/trebuchet-ms/Trebuchet-MS-Italic.woff2"],
                            "fontWeight": "400",
                            "fontStyle": "italic",
                            "fontFamily": "\"Trebuchet MS\""
                        }
                    ]
                }
