        "layout": {
            "contentSize": "1280px",
            "wideSize": "1440px"
        },
        "shadow": {
            "defaultPresets": false,
            "presets": [
                {
                    "name": "Light Dark",
                    "shadow": "0px 5px 15px rgba(0, 0, 0, 0.4)",
                    "slug": "rsf-light-dark"
                }
            ]
        },
        "spacing": {
            "defaultSpacingSizes": false,
            "spacingSizes": [
                {
                    "name": "Edge Gap",
                    "size": "1rem",
                    "slug": "rsf-edge-gap"
                },
                {
                    "name": "Elements Gap",
                    "size": "1.5rem",
                    "slug": "rsf-elements-gap"
                },
                {
                    "name": "2X Small",
                    "size": "20px",
                    "slug": "rsf-20"
                },
                {
                    "name": "Small",
                    "size": "30px",
                    "slug": "rsf-30"
                },
                {
                    "name": "Medium",
                    "size": "40px",
                    "slug": "rsf-40"
                },
                {
                    "name": "Regular",
                    "size": "clamp(30px, 5vw, 50px)",
                    "slug": "rsf-50"
                },
                {
                    "name": "Large",
                    "size": "clamp(30px, 7vw, 70px)",
                    "slug": "rsf-60"
                },
                {
                    "name": "X-Large",
                    "size": "clamp(70px, 7vw, 100px)",
                    "slug": "rsf-100"
                },
                {
                    "name": "Section Padding",
                    "size": "clamp(70px, 10vw, 100px)",
                    "slug": "rsf-section-padding"
                }
            ],
            "units": [
                "%",
                "px",
                "em",
                "rem",
                "vh",
                "vw"
            ]
        },
        "typography": {
            "defaultFontSizes": false,
            "fluid": true,
            "fontFamilies": [
                {
                    "name": "Source Sans 3",
                    "slug": "source-sans-3",
                    "fontFamily": "\"Source Sans 3\", sans-serif",
                    "fontFace": [
