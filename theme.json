        "spacing": {
            "defaultSpacingSizes": false,
            "spacingSizes": [
                {
                    "name": "Edge Gap",
                    "size": "1rem",
                    "slug": "rsf-edge-gap"
                },
                {
                    "name": "Elements Gap",
                    "size": "1.5rem",
                    "slug": "rsf-elements-gap"
