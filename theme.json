            "fontSizes": [
                {
                    "name": "Heading One",
                    "size": "72px",
                    "slug": "rsf-heading-one",
                    "fluid": {
                        "min": "40px",
                        "max": "72px"
                    }
                },
                {
                    "name": "Heading Two",
                    "size": "48px",
                    "slug": "rsf-heading-two",
                    "fluid": {
